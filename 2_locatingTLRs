## Make database for the reference genome

 makeblastdb -in ./refgenome.fa -dbtype nucl -out ./ref_genome_db

## Running BLASTn to look for matches with CDS

blastn -query ./CDS.fasta -db ./ref_genome_db -out ./results.txt -outfmt "6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore qlen" \ -num_threads 4

## Running tblastn to look for matches with protein sequences

tblastn -query queries.faa -db ref_genome_db \
  -out tblastn_results.txt \
  -outfmt "6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore qlen" \
  -num_threads 4

## Generate fasta files from the reference genome for conducting Reciprocal Best Hit (RBH) tests

module load bedtools 

bedtools getfasta \
  -fi reference.fasta \
  -bed regions.bed \
  -fo output.fasta \
  -name
